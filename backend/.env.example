# ============================================
# Velora Motors Backend — Environment Variables
# ============================================
# Copy this file to ".env" and fill in real values.
# Never commit the real ".env" file to git or share it publicly.

# ---- Server ----
PORT=3001

# ---- CORS: the exact URL(s) your website will be hosted at ----
# For local testing with the HTML file opened directly, you can leave this as "*"
# Once your site has a real domain, set it to that domain for security, e.g.:
# ALLOWED_ORIGIN=https://veloramotors.in
ALLOWED_ORIGIN=*

# ---- Supabase (free Postgres database) ----
# Get these from: https://supabase.com -> your project -> Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---- Resend (free email sending, 100 emails/day on free tier) ----
# Get this from: https://resend.com -> API Keys
RESEND_API_KEY=re_your_api_key_here

# Email address that should RECEIVE inquiry/newsletter notifications (your inbox)
NOTIFY_EMAIL=support@veloramotors.in

# Email address that emails will be SENT FROM.
# On Resend's free tier, until you verify your own domain, you must use:
# onboarding@resend.dev
# Once you verify veloramotors.in in Resend, change this to e.g. noreply@veloramotors.in
FROM_EMAIL=onboarding@resend.dev
